#!/bin/bash

# Deploy script for t-sui
# Bumps version, creates a git tag, builds a tarball, and creates a GitHub release.

set -euo pipefail

for cmd in npm node gh; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
        echo "Error: $cmd is required but not installed."
        exit 1
    fi
done

# Check if working tree is clean
if ! git diff-index --quiet HEAD --; then
    echo "Error: Working tree has uncommitted changes. Please commit or stash them first."
    exit 1
fi

CURRENT_BRANCH=$(git branch --show-current)
echo "Current branch: $CURRENT_BRANCH"

echo "Fetching latest tags from origin..."
git fetch origin --tags

LATEST_TAG=$(git tag -l "v*" | grep -E '^v[0-9]+\.[0-9]+\.[0-9]+$' | sort -V | tail -1 || true)

if [ -z "$LATEST_TAG" ]; then
    PKG_VERSION=$(node -p "require('./package.json').version")
    if [[ "$PKG_VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
        NEW_VERSION="v$PKG_VERSION"
        echo "No existing semver tags found. Starting from package.json version: $NEW_VERSION"
    else
        echo "Error: package.json version is not valid semver: $PKG_VERSION"
        exit 1
    fi
else
    echo "Latest version: $LATEST_TAG"
    MAJOR=$(echo "$LATEST_TAG" | sed 's/^v\([0-9]*\)\..*/\1/')
    MINOR=$(echo "$LATEST_TAG" | sed 's/^v[0-9]*\.\([0-9]*\)\..*/\1/')
    PATCH=$(echo "$LATEST_TAG" | sed 's/^v[0-9]*\.[0-9]*\.\([0-9]*\)$/\1/')
    NEW_PATCH=$((PATCH + 1))
    NEW_VERSION="v$MAJOR.$MINOR.$NEW_PATCH"
    echo "New version: $NEW_VERSION"
fi

if git rev-parse "$NEW_VERSION" >/dev/null 2>&1; then
    echo "Error: Tag already exists: $NEW_VERSION"
    exit 1
fi

# Update version in package.json
SEMVER="${NEW_VERSION#v}"
node -e "
const fs = require('fs');
const pkg = JSON.parse(fs.readFileSync('package.json', 'utf8'));
pkg.version = '$SEMVER';
fs.writeFileSync('package.json', JSON.stringify(pkg, null, 2) + '\n');
"
echo "Updated package.json version to $SEMVER"

echo "Running type check..."
npm run check

echo "Running tests..."
npm test

# Build tarball
TARBALL="t-sui-${SEMVER}.tgz"
echo "Building tarball..."
npm pack 2>/dev/null
echo "Tarball created: $TARBALL"

# Commit version bump
git add package.json
git commit -m "release $NEW_VERSION"

echo "Creating tag $NEW_VERSION..."
git tag -a "$NEW_VERSION" -m "Release $NEW_VERSION"

echo "Pushing to origin..."
git push origin "$CURRENT_BRANCH" --follow-tags

# Create GitHub release with tarball attached
echo "Creating GitHub release..."
gh release create "$NEW_VERSION" "$TARBALL" \
    --title "$NEW_VERSION" \
    --notes "Install: \`npm install https://github.com/michalCapo/t-sui/releases/download/$NEW_VERSION/$TARBALL\`"

# Clean up local tarball
rm -f "$TARBALL"

echo ""
echo "Successfully deployed $NEW_VERSION"
echo ""
echo "Install:"
echo "  npm install https://github.com/michalCapo/t-sui/releases/download/$NEW_VERSION/$TARBALL"
